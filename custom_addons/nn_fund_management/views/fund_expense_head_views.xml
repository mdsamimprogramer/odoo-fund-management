<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_expense_head_list" model="ir.ui.view">
        <field name="name">nn.fund.expense.head.list</field>
        <field name="model">nn.fund.expense.head</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="allocated_amount"/>
                <field name="available_amount"/>
                <field name="hold_amount"/>
                <field name="spent_amount"/>
                <field name="incoming_transfer_amount"/>
                <field name="outgoing_transfer_amount"/>
            </list>
        </field>
    </record>

    <record id="view_fund_expense_head_form" model="ir.ui.view">
        <field name="name">nn.fund.expense.head.form</field>
        <field name="model">nn.fund.expense.head</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="company_id"/>
                        </group>
                        <group>
                            <field name="allocated_amount" readonly="1"/>
                            <field name="available_amount" readonly="1"/>
                            <field name="hold_amount" readonly="1"/>
                            <field name="spent_amount" readonly="1"/>
                            <field name="incoming_transfer_amount" readonly="1"/>
                            <field name="outgoing_transfer_amount" readonly="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_fund_expense_head" model="ir.actions.act_window">
        <field name="name">Expense Heads</field>
        <field name="res_model">nn.fund.expense.head</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
