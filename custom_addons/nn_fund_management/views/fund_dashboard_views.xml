<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_dashboard_form" model="ir.ui.view">
        <field name="name">nn.fund.dashboard.form</field>
        <field name="model">nn.fund.dashboard</field>
        <field name="arch" type="xml">
            <form create="0" edit="0" delete="0">
                <sheet>
                    <h1><field name="name"/></h1>
                    <group>
                        <group string="Summary">
                            <field name="total_received"/>
                            <field name="unassigned_balance"/>
                            <field name="held_balance"/>
                            <field name="assigned_balance"/>
                            <field name="spent_balance"/>
                            <field name="pending_approval_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Project Balances">
                            <field name="project_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="allocated_amount"/>
                                    <field name="available_amount"/>
                                    <field name="hold_amount"/>
                                    <field name="spent_amount"/>
                                    <field name="incoming_transfer_amount"/>
                                    <field name="outgoing_transfer_amount"/>
                                </list>
                            </field>
                        </page>
                        <page string="Expense Head Balances">
                            <field name="expense_head_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="allocated_amount"/>
                                    <field name="available_amount"/>
                                    <field name="hold_amount"/>
                                    <field name="spent_amount"/>
                                    <field name="incoming_transfer_amount"/>
                                    <field name="outgoing_transfer_amount"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_fund_dashboard" model="ir.actions.act_window">
        <field name="name">Fund Dashboard</field>
        <field name="res_model">nn.fund.dashboard</field>
        <field name="view_mode">form</field>
        <field name="res_id" ref="nn_fund_management.fund_dashboard_main"/>
    </record>
</odoo>
