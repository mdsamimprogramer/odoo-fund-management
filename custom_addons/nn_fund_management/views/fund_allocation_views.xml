<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_allocation_list" model="ir.ui.view">
        <field name="name">nn.fund.allocation.list</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="account_id"/>
                <field name="destination_type"/>
                <field name="project_id"/>
                <field name="expense_head_id"/>
                <field name="amount"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_fund_allocation_form" model="ir.ui.view">
        <field name="name">nn.fund.allocation.form</field>
        <field name="model">nn.fund.allocation</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" type="object" string="Submit" class="btn-primary" invisible="status != 'draft'"/>
                    <button name="action_send_to_gm" type="object" string="Send to GM" class="btn-primary" invisible="status != 'submitted'"/>
                    <button name="action_gm_approve" type="object" string="GM Approve" class="btn-primary" invisible="status != 'gm_approval'" groups="nn_fund_management.group_fund_gm_approver"/>
                    <button name="action_md_approve" type="object" string="MD Approve" class="btn-primary" invisible="status != 'md_approval'" groups="nn_fund_management.group_fund_md_approver"/>
                    <button name="action_reject" type="object" string="Reject" invisible="status not in ('gm_approval', 'md_approval')" groups="nn_fund_management.group_fund_gm_approver,nn_fund_management.group_fund_md_approver"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="status not in ('draft', 'submitted', 'gm_approval', 'md_approval')"/>
                    <button name="action_print_report" type="object" string="Print" invisible="status == 'draft'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="account_id"/>
                            <field name="destination_type"/>
                            <field name="project_id" invisible="destination_type != 'project'" required="destination_type == 'project'"/>
                            <field name="expense_head_id" invisible="destination_type != 'expense_head'" required="destination_type == 'expense_head'"/>
                        </group>
                        <group>
                            <field name="amount"/>
                            <field name="date"/>
                            <field name="requested_by_id" readonly="1"/>
                            <field name="company_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="comments"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_fund_allocation" model="ir.actions.act_window">
        <field name="name">Fund Allocations</field>
        <field name="res_model">nn.fund.allocation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
