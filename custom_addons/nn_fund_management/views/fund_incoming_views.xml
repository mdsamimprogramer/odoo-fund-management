<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_fund_incoming_list" model="ir.ui.view">
        <field name="name">nn.fund.incoming.list</field>
        <field name="model">nn.fund.incoming</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="date"/>
                <field name="account_id"/>
                <field name="reference"/>
                <field name="sender"/>
                <field name="amount"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_fund_incoming_form" model="ir.ui.view">
        <field name="name">nn.fund.incoming.form</field>
        <field name="model">nn.fund.incoming</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_post" type="object" string="Post" class="btn-primary" invisible="status != 'draft'"/>
                    <button name="action_cancel" type="object" string="Cancel" invisible="status != 'draft'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="account_id"/>
                            <field name="amount"/>
                            <field name="date"/>
                        </group>
                        <group>
                            <field name="reference"/>
                            <field name="sender"/>
                            <field name="company_id"/>
                            <field name="attachment" filename="attachment_filename"/>
                            <field name="attachment_filename" invisible="1"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_fund_incoming" model="ir.actions.act_window">
        <field name="name">Incoming Funds</field>
        <field name="res_model">nn.fund.incoming</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
