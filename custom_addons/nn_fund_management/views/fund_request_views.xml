<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Minimal list view -->
        <record id="view_fund_request_list" model="ir.ui.view">
            <field name="name">fund.request.list</field>
            <field name="model">fund.request</field>
            <field name="arch" type="xml">
                <list>
                    <field name="request_number"/>
                </list>
            </field>
        </record>

        <!-- Minimal form view -->
        <record id="view_fund_request_form" model="ir.ui.view">
            <field name="name">fund.request.form</field>
            <field name="model">fund.request</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="request_number"/>
                            <field name="employee_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Minimal search view -->
        <record id="view_fund_request_search" model="ir.ui.view">
            <field name="name">fund.request.search</field>
            <field name="model">fund.request</field>
            <field name="arch" type="xml">
                <search>
                    <field name="request_number"/>
                </search>
            </field>
        </record>

    </data>
</odoo>