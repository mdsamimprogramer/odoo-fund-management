<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="module_category_nn_fund_management" model="ir.module.category">
            <field name="name">NN Fund Management</field>
            <field name="sequence">25</field>
        </record>

        <record id="group_fund_user" model="res.groups">
            <field name="name">Fund User</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="comment">Can create allocation and requisition requests.</field>
        </record>

        <record id="group_fund_finance_user" model="res.groups">
            <field name="name">Finance User</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
            <field name="comment">Can post incoming funds, bills and transfers.</field>
        </record>

        <record id="group_fund_gm_approver" model="res.groups">
            <field name="name">GM Approver</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('group_fund_user'))]"/>
            <field name="comment">Can perform first-level GM approval.</field>
        </record>

        <record id="group_fund_md_approver" model="res.groups">
            <field name="name">MD Approver</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[(4, ref('group_fund_gm_approver'))]"/>
            <field name="comment">Can perform second-level MD approval.</field>
        </record>

        <record id="group_fund_administrator" model="res.groups">
            <field name="name">Fund Administrator</field>
            <field name="category_id" ref="module_category_nn_fund_management"/>
            <field name="implied_ids" eval="[
                (4, ref('group_fund_finance_user')),
                (4, ref('group_fund_md_approver'))
            ]"/>
            <field name="comment">Full administration access for fund management configuration.</field>
        </record>
    </data>
</odoo>
