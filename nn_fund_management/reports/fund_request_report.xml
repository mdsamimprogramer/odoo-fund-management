            <field name="name">Fund Request Report</field>
            <field name="type">ir.actions.report</field>
            <field name="model">fund.request</field>
            <field name="report_type">qweb-pdf</field>
            <field name="report_name">nn_fund_management.report_fund_request_template</field>
