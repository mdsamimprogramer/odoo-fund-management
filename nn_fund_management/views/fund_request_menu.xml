<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        
        <!-- ==================== ACTION WINDOW ==================== -->
        <record id="action_fund_request" model="ir.actions.act_window">
            <field name="name">Fund Requests</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">fund.request</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_fund_request_search"/>
            <field name="context">{'search_default_draft': 1}</field>
            <field name="help" type="html">
                <p class="oe_view_nocontent_create">
                    Click to create a new fund request.
                </p>
                <p>
                    Use fund requests to manage employee fund requests with proper workflow
                    and approval process. Submit requests for management review and approval.
                </p>
            </field>
        </record>
        
        <!-- ==================== MENU ITEMS ==================== -->
        
        <!-- Main Menu -->
        <menuitem 
            id="menu_fund_management" 
            name="Fund Management" 
            sequence="50"
            web_icon="nn_fund_management,static/description/icon.png"/>
        
        <!-- Fund Requests Submenu -->
        <menuitem 
            id="menu_fund_request" 
            name="Fund Requests" 
            parent="menu_fund_management"
            action="action_fund_request" 
            sequence="10"/>
        
    </data>
</odoo>
